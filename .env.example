# =============================================================================
# NEXOMAIL — Environment Variables
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no git.
# =============================================================================

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# AUTH (Better Auth)
# Gere um secret forte: openssl rand -base64 32
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# Local via Docker Compose — não alterar para desenvolvimento local
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://nexomail:nexomail@localhost:5432/nexomail

# -----------------------------------------------------------------------------
# CACHE (Redis)
# Local via Docker Compose — não alterar para desenvolvimento local
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# GOOGLE (Gmail API + OAuth Login)
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# APIs necessárias: Gmail API, Google People API
# Redirect URI: http://localhost:3000/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# MICROSOFT (Outlook + OAuth Login)
# portal.azure.com → Azure Active Directory → App registrations
# Permissions: Mail.Read, Mail.ReadWrite, Mail.Send, User.Read
# Redirect URI: http://localhost:3000/api/auth/callback/microsoft
# -----------------------------------------------------------------------------
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common

# -----------------------------------------------------------------------------
# AI — ANTHROPIC (Claude — LLM primário do agente)
# console.anthropic.com → API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# AI — OPENAI (GPT-4o — fallback do agente)
# platform.openai.com → API Keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# EMAIL TRANSACIONAL (Resend — para emails do sistema: boas-vindas, reset, etc.)
# resend.com → API Keys
# Opcional no MVP — pode deixar vazio para desabilitar emails do sistema
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@nexomail.app

# -----------------------------------------------------------------------------
# IMAP / SMTP (credenciais configuradas pelo usuário dentro do app)
# Estas variáveis NÃO são necessárias aqui — cada conta IMAP é cadastrada
# diretamente na interface pelo usuário.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# ENCRIPTAÇÃO (chave para dados sensíveis: tokens OAuth, credenciais IMAP)
# Gere com: openssl rand -base64 32
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# MONITORAMENTO (opcional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
